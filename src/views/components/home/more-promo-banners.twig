{# More Promotional Banners Component - MOBEX Design #}
<section class="more-promo-banners">
    <div class="container">
        <div class="banner-grid-2">
            {% if banners and banners|length > 0 %}
                {% for banner in banners %}
                    <div class="promo-banner {{ banner.class|default('lamps-banner') }}">
                        <div class="banner-content">
                            {% if banner.badge %}
                                <span class="banner-badge {{ banner.badge_class|default('green') }}">{{ banner.badge }}</span>
                            {% endif %}
                            {% if banner.title %}
                                <h2>{{ banner.title }}</h2>
                            {% endif %}
                            {% if banner.mega_title %}
                                <h2 class="banner-mega">{{ banner.mega_title }}</h2>
                            {% endif %}
                            {% if banner.subtitle %}
                                <p>{{ banner.subtitle }}</p>
                            {% endif %}
                            {% if banner.button_text and banner.button_url %}
                                <a href="{{ banner.button_url }}" class="banner-btn">{{ banner.button_text }} <i class="sicon-arrow-right"></i></a>
                            {% endif %}
                            {% if banner.show_presale_chat %}
                                <button class="presale-chat-btn">Presale chat</button>
                            {% endif %}
                        </div>
                        {% if banner.image %}
                            <div class="banner-image">
                                <img src="{{ banner.image.url }}" alt="{{ banner.image.alt|default(banner.title) }}">
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            {% else %}
                {# Fallback static banners #}
                <div class="promo-banner lamps-banner">
                    <div class="banner-content">
                        <span class="banner-badge green">Top Brands</span>
                        <h2>LAMPS AND LIGHTS</h2>
                        <h2 class="banner-mega">MEGA SALE</h2>
                        <p>2023 models included!</p>
                        <button class="banner-btn">Shop now <i class="sicon-arrow-right"></i></button>
                        <button class="presale-chat-btn">Presale chat</button>
                    </div>
                    <div class="banner-image">
                        <img src="{{ 'images/lamps.jpg'|asset }}" alt="Lamps">
                    </div>
                </div>
                <div class="promo-banner filters-banner">
                    <div class="banner-content">
                        <span class="banner-badge red">Big Sales!</span>
                        <h2>AIR FILTERS</h2>
                        <p>Premium quality</p>
                        <button class="banner-btn">Shop now <i class="sicon-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="{{ 'images/air-filters.jpg'|asset }}" alt="Air Filters">
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</section>
