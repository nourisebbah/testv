{# Footer Component - MOBEX Design #}
{# Using documented store objects from sallatheme.txt #}
<footer class="main-footer">
    {# Footer Top - Green Background #}
    <div class="footer-top">
        <div class="container">
            <div class="footer-features">
                <div class="footer-feature">
                    <i class="sicon-headset"></i>
                    <h3>Expert Service</h3>
                    <p>Our friendly team's on hand seven days a week.</p>
                </div>
                <div class="footer-feature">
                    <i class="sicon-hand-holding-usd"></i>
                    <h3>Amazing Value</h3>
                    <p>The brands you prefer, at the prices you crave.</p>
                </div>
                <div class="footer-feature">
                    <i class="sicon-truck"></i>
                    <h3>Fast & Free Shipping</h3>
                    <p>Order ships out in a snap, and delivers in 1-3 days.</p>
                </div>
                <div class="footer-feature">
                    <i class="sicon-box"></i>
                    <h3>Unbeatable Selection</h3>
                    <p>Everything you want for your car, all in one place.</p>
                </div>
            </div>
        </div>
    </div>

    {# Footer Main - Black Background #}
    <div class="footer-main">
        <div class="container">
            <div class="footer-content">
                {# Column 1: Logo, Social, Newsletter #}
                <div class="footer-column">
                    <div class="footer-logo">
                        <a href="{{ store.url }}">
                            {% if store.logo %}
                                <img src="{{ store.logo }}" alt="{{ store.name }}">
                            {% else %}
                                <h2>{{ store.name }}</h2>
                                <p>AUTO PARTS & ACCESSORIES</p>
                            {% endif %}
                        </a>
                    </div>
                    <div class="social-links">
                        {% if store.social.facebook %}<a href="{{ store.social.facebook }}"><i class="sicon-facebook"></i></a>{% endif %}
                        {% if store.social.instagram %}<a href="{{ store.social.instagram }}"><i class="sicon-instagram"></i></a>{% endif %}
                        {% if store.social.linkedin %}<a href="{{ store.social.linkedin }}"><i class="sicon-linkedin"></i></a>{% endif %}
                        {% if store.social.twitter %}<a href="{{ store.social.twitter }}"><i class="sicon-twitter"></i></a>{% endif %}
                        {% if store.social.youtube %}<a href="{{ store.social.youtube }}"><i class="sicon-youtube"></i></a>{% endif %}
                        {% if store.social.whatsapp %}<a href="https://wa.me/{{ store.social.whatsapp }}"><i class="sicon-whatsapp"></i></a>{% endif %}
                        {% if store.social.maroof %}<a href="{{ store.social.maroof }}" target="_blank" rel="noreferrer"><img src="{{ 'images/maroof-footer.png'|cdn }}" alt="maroof" style="width: 40px; height: 40px; border-radius: 50%;"></a>{% endif %}
                    </div>
                    <div class="newsletter">
                        <p>What's inside: new arrivals, exclusive sales, truck news and more!</p>
                        <div class="newsletter-form">
                            <input type="email" placeholder="Email address">
                            <button type="submit"><i class="sicon-arrow-right"></i></button>
                        </div>
                    </div>
                </div>

                {# Column 2: Account Links #}
                <div class="footer-column">
                    <h3>Account</h3>
                    <ul>
                        <li><a href="{{ page('customer.dashboard') }}">Dashboard</a></li>
                        <li><a href="{{ page('customer.orders') }}">Orders</a></li>
                        <li><a href="{{ page('customer.wishlist') }}">Wishlist</a></li>
                        <li><a href="#">My garage</a></li>
                        <li><a href="{{ page('customer.addresses') }}">Addresses</a></li>
                    </ul>
                </div>

                {# Column 3: Catalog Links #}
                <div class="footer-column">
                    <h3>Catalog</h3>
                    <ul>
                        <li><a href="{{ page('categories') }}">Shop by parts</a></li>
                        <li><a href="{{ page('brands') }}">Shop by brands</a></li>
                        <li><a href="#">Shop by make</a></li>
                        <li><a href="{{ page('offers') }}">Promotions</a></li>
                        <li><a href="#">Sitemap</a></li>
                    </ul>
                </div>

                {# Column 4: Help Links #}
                <div class="footer-column">
                    <h3>Help</h3>
                    <ul>
                        <li><a href="#">Features</a></li>
                        <li><a href="#">FAQ</a></li>
                        <li><a href="{{ page('about') }}">About us</a></li>
                        <li><a href="#">Career</a></li>
                        <li><a href="{{ page('contact') }}">Contact us</a></li>
                    </ul>
                </div>

                {# Column 5: Contact Info #}
                <div class="footer-column">
                    <h3>Need help? / Contact us</h3>
                    <div class="contact-info">
                        <p><i class="sicon-map-marker-alt"></i> 7031 N 35th Ave, Phoenix Arkansas United States</p>
                        <p><i class="sicon-phone"></i> Call us between 8 AM - 10 PM<br><strong>{% if store.contacts.mobile %}{{ store.contacts.mobile }}{% else %}6668 5555 8464{% endif %}</strong></p>
                        <p><i class="sicon-headset"></i> Live chat<br><a href="#">Chat with an Expert</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Footer Bottom - Copyright #}
    <div class="footer-bottom">
        <div class="container">
            <div class="md:flex items-center justify-between py-4 text-center">
                <span class="text-sm copyright-text">{% hook copyright %}</span>
                <salla-payments></salla-payments>
            </div>
        </div>
    </div>
</footer>
